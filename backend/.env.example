# Required
DATABASE_URL=postgresql://user:password@localhost:5432/trackvibe
JWT_SECRET=change-me-in-production

# Voice (optional)
GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash

# Server
# PORT=3000
# HOST=0.0.0.0
# CORS_ORIGIN=http://localhost:5173
# FRONTEND_ORIGIN=http://localhost:5173

# Redis (optional — enables rate limiting, food cache, async voice, event bus)
# REDIS_URL=redis://localhost:6379

# OAuth (optional)
# GOOGLE_CLIENT_ID=
# FACEBOOK_APP_ID=
# TWITTER_CLIENT_ID=
# TWITTER_CLIENT_SECRET=
# TWITTER_REDIRECT_URI=

# Event bus (optional)
# EVENT_TRANSPORT=redis
# EVENT_QUEUE_URL=
# AWS_REGION=

# Per-context DB (optional)
# BODY_DATABASE_URL=
# ENERGY_DATABASE_URL=
# GOALS_DATABASE_URL=

# Gateway mode (optional)
# BODY_SERVICE_URL=
# ENERGY_SERVICE_URL=
# GOALS_SERVICE_URL=

# Rate limiting (optional)
# API_RATE_LIMIT_MAX=200
# AUTH_RATE_LIMIT_MAX=10

# MCP server (optional)
# TRACKVIBE_MCP_SECRET=
# TRACKVIBE_MCP_USER_ID=

# Email (optional)
# RESEND_API_KEY=

# Workers
# SEPARATE_WORKERS=false
# SKIP_SCHEMA_INIT=false
